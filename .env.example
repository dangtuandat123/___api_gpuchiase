# Runware API key — get from https://my.runware.ai
RUNWARE_API_KEY=your_runware_api_key_here

# Supabase — get from your project dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Provider secret — the API key you register on ChiaseGPU for this provider.
# ChiaseGPU sends this key in the Authorization header when forwarding requests.
# If not set, auth check is skipped (useful for local dev).
PROVIDER_SECRET=your_provider_secret_here

